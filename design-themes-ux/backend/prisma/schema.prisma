model BuilderPage {
  id          String           @id @default(cuid())
  storeId     String
  /// 'home' | 'collection' | 'product' | 'landing' | 'blog' | 'checkout' | 'custom'
  pageType    String           @db.VarChar(50)
  /// Unique per store+pageType: 'home' | 'landing:summer-sale' | 'collection:jewellery'
  slug        String           @db.VarChar(200)
  /// Merchant-visible display name e.g. "Homepage", "Summer Sale 2026"
  name        String           @db.VarChar(200)
  /// 'LIVE' | 'DRAFT'
  status      String           @default("LIVE") @db.VarChar(20)
  /// Incremented on every publish — supports future version history and rollback
  version     Int              @default(1)
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  store    Store            @relation("BuilderPages", fields: [storeId], references: [id], onDelete: Cascade)
  sections BuilderSection[]

  @@unique([storeId, pageType, slug])
  @@index([storeId, pageType])
  @@map("builder_pages")
}

model BuilderSection {
  id          String      @id @default(cuid())
  storeId     String
  pageId      String
  /// Strongly typed via SECTION_TYPE enum on the frontend
  /// e.g. 'hero_banner' | 'featured_products' | 'campaign_grid' | 'newsletter'
  sectionType String      @db.VarChar(80)
  /// Merchant-editable display name shown in the Homepage Builder overview
  label       String      @db.VarChar(200)
  sortOrder   Int         @default(0)
  isEnabled   Boolean     @default(true)
  /// true = read-only in Page Builder (e.g. trust_badges managed from Theme Engine)
  isLocked    Boolean     @default(false)
  /// 'LIVE' | 'DRAFT' | 'SCHEDULED' | 'DISABLED'
  status      String      @default("LIVE") @db.VarChar(20)
  /// Section-specific config JSON — schema per sectionType defined in SectionRegistry.ts (Phase 2+)
  config      Json
  goLiveAt    DateTime?
  expireAt    DateTime?
  /// userId of the last user to modify this section — for audit trail
  updatedBy   String?     @db.VarChar(191)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  page  BuilderPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  store Store       @relation("BuilderSections", fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, pageId, sortOrder])
  @@index([storeId, sectionType])
  @@index([pageId], map: "builder_sections_pageId_fkey")
  @@map("builder_sections")
}

