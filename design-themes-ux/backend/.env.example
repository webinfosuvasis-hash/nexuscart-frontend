# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL="mysql://root:password@localhost:3306/nexuscart"

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
PREVIEW_JWT_SECRET=super-secret-preview-key-change-in-production

# Cors
CORS_ORIGIN=http://localhost:5173

# Supabase (for storage / edge functions)
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@nexuscart.com
SMTP_PASS=your-smtp-password
SMTP_FROM="NexusCart <noreply@nexuscart.com>"

# Stripe (payments / subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (India billing)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-secret

# Storage (S3 / Cloudflare R2)
S3_BUCKET=nexuscart-uploads
S3_REGION=ap-south-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://your-r2-endpoint
